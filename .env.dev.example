# --- App ---
ENVIRONMENT=development         # development | staging | production | test
DEBUG=true
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=                     # min 32 random chars (e.g. `openssl rand -hex 32`)
FRONTEND_URL=http://localhost:3000

# --- Datastores ---
DATABASE_URL=postgresql+asyncpg://app:dev@localhost:5432/gbp_review_manager
REDIS_URL=redis://localhost:6379/0

# --- Crypto / Auth ---
# Fernet key used to encrypt OAuth tokens at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
OAUTH_TOKEN_ENCRYPTION_KEY=

# JWT signing — min 32 random chars (e.g. `openssl rand -hex 32`)
JWT_SECRET=
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=30

# --- Google Business Profile OAuth ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/oauth/google/callback

# --- LLM provider ---
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# --- Billing (Lemon Squeezy) ---
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_STARTER=
LEMONSQUEEZY_VARIANT_PRO=
LEMONSQUEEZY_VARIANT_BUSINESS=

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com

# --- Optional ---
TELEGRAM_BOT_TOKEN=
SENTRY_DSN=
CELERY_TASK_ALWAYS_EAGER=false

# --- Rate limits ---
RATE_LIMIT_SIGNUP_PER_HOUR=3
RATE_LIMIT_LOGIN_PER_MINUTE=5

# --- Misc ---
UNDO_GRACE_PERIOD_MINUTES=10

# ─── Frontend ────────────────────────────────────────────────────────────────
# Le frontend a été extrait dans le dépôt voisin `gbp-pilot-review-website/`.
# Ses variables (NEXT_PUBLIC_BACKEND_URL, AUTH_SECRET, NEXT_PUBLIC_FORMSPREE_ENDPOINT)
# se configurent dans ../gbp-pilot-review-website/.env.local et n'ont plus rien à
# faire ici.
