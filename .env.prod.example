# ============================================================================
# .env.prod.example — Template du fichier .env de PRODUCTION
# ============================================================================
# Comment l'utiliser sur le VPS :
#   cp .env.prod.example .env
#   nano .env   # remplace tous les __SET_ME__ par les vraies valeurs (Bitwarden)
#   chmod 600 .env
# ============================================================================

# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=__SET_ME__
FRONTEND_URL=https://pilot-review.com
CORS_ORIGINS=https://pilot-review.com,https://www.pilot-review.com

# ----------------------------------------------------------------------------
# Postgres (utilisé par le service postgres dans docker-compose.prod.yml)
# ----------------------------------------------------------------------------
POSTGRES_DB=gbp_pilot_review
POSTGRES_USER=postgres
POSTGRES_PASSWORD=__SET_ME__

# ----------------------------------------------------------------------------
# Datastores (utilisé par l'app, pointe vers les services Docker internes)
# ----------------------------------------------------------------------------
# Note : "postgres" et "redis" sont les noms de services Docker, pas localhost.
DATABASE_URL=postgresql+asyncpg://postgres:__SET_ME__@postgres:5432/gbp_pilot_review
REDIS_URL=redis://redis:6379/0

# ----------------------------------------------------------------------------
# Crypto / Auth
# ----------------------------------------------------------------------------
# Fernet key : chiffrement des tokens OAuth en DB
# Générer : python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
OAUTH_TOKEN_ENCRYPTION_KEY=__SET_ME__

# JWT : signature des tokens d'authentification utilisateur
# Générer : python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=__SET_ME__
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=30

# ----------------------------------------------------------------------------
# Google Business Profile OAuth
# ----------------------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=__SET_ME__
GOOGLE_OAUTH_CLIENT_SECRET=__SET_ME__
GOOGLE_OAUTH_REDIRECT_URI=https://api.pilot-review.com/api/v1/oauth/google/callback

# ----------------------------------------------------------------------------
# LLM provider (Anthropic Claude)
# ----------------------------------------------------------------------------
CLAUDE_API_KEY=__SET_ME__
CLAUDE_MODEL=claude-sonnet-4-6

# ----------------------------------------------------------------------------
# Billing (Lemon Squeezy)
# ----------------------------------------------------------------------------
LEMONSQUEEZY_API_KEY=__SET_ME__
LEMONSQUEEZY_WEBHOOK_SECRET=__SET_ME__
LEMONSQUEEZY_STORE_ID=__SET_ME__
LEMONSQUEEZY_VARIANT_STARTER=
LEMONSQUEEZY_VARIANT_PRO=
LEMONSQUEEZY_VARIANT_BUSINESS=

# ----------------------------------------------------------------------------
# Email (Resend)
# ----------------------------------------------------------------------------
RESEND_API_KEY=__SET_ME__
RESEND_FROM_EMAIL=notifications@pilot-review.com

# ----------------------------------------------------------------------------
# Telegram (notifications push)
# ----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=__SET_ME__

# ----------------------------------------------------------------------------
# Observabilité (Sentry)
# ----------------------------------------------------------------------------
SENTRY_DSN=__SET_ME__

# ----------------------------------------------------------------------------
# Celery
# ----------------------------------------------------------------------------
CELERY_TASK_ALWAYS_EAGER=false

# ----------------------------------------------------------------------------
# Rate limits
# ----------------------------------------------------------------------------
RATE_LIMIT_SIGNUP_PER_HOUR=3
RATE_LIMIT_LOGIN_PER_MINUTE=5

# ----------------------------------------------------------------------------
# Misc
# ----------------------------------------------------------------------------
UNDO_GRACE_PERIOD_MINUTES=10