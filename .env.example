ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=change-me-please
FRONTEND_URL=http://localhost:3000

DATABASE_URL=postgresql+asyncpg://app:dev@localhost:5432/gbp_review_manager
REDIS_URL=redis://localhost:6379/0

# Generate via: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
OAUTH_TOKEN_ENCRYPTION_KEY=

JWT_SECRET=change-me-jwt
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=30

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/oauth/google/callback

CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_STORE_ID=

RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com

TELEGRAM_BOT_TOKEN=

SENTRY_DSN=

# ─── Frontend ────────────────────────────────────────────────────────────────
# Le frontend a été extrait dans le dépôt voisin `gbp-pilot-review-website/`.
# Ses variables (NEXT_PUBLIC_BACKEND_URL, AUTH_SECRET, NEXT_PUBLIC_FORMSPREE_ENDPOINT)
# se configurent dans ../gbp-pilot-review-website/.env.local et n'ont plus rien à
# faire ici.
